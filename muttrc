source ~/.mutt/aliases
source ~/.mutt/colors

set mailcap_path = ~/.mutt/mailcap

set sort="threads"
set strict_threads="yes"

set sort_browser="reverse-date"
set sort_aux="reverse-last-date-received"

unset collapse_unread

bind index - collapse-thread
bind index _ collapse-all

# render HTML and some other types as text
auto_view text/html application/text application/pdf

# many companies send very poor text/plain parts, so prefer html to text/plain
alternative_order text/enriched text/html text/plain text

set date_format="%m/%d %I:%M"
set index_format="%2C %Z %?X?A& ? %D %-15.15F %s (%-4.4c)"
set pager_context = 3
set pager_index_lines   = 10

set markers = no
set mark_old = no
set mime_forward = yes
set wait_key = no
set rfc2047_parameters = yes

# General remappings
bind editor <space> noop
bind index D delete-message
bind index G last-entry
bind index U undelete-message
bind index,pager d half-down
bind index,pager \Cd half-down
bind index,pager g noop
bind index gg first-entry
bind index,pager u half-up
bind index,pager \Cu half-up
bind index j next-entry
bind index k previous-entry
bind pager G bottom
bind pager gg top
bind pager j next-line
bind pager k previous-line
bind index,pager S save-message
bind index s sort-mailbox
bind index,pager R group-reply
bind pager \Cp previous-undeleted
bind pager \Cn next-undeleted

# Tag bindings
bind index \Ct noop
bind index \Ctt tag-thread
bind index \Ctp tag-pattern
bind index \Ctu untag-pattern

bind index F imap-fetch-mail

# View attachments properly.
bind attach <return> view-mailcap
set fast_reply           # skip to compose when replying
set fcc_attach           # save attachments with the body
unset mime_forward       # forward attachments as part of body
set forward_format = "Fwd: %s"       # format of subject when forwarding
set forward_decode                   # decode when forwarding
set forward_quote                    # include message in forwards
set reverse_name                     # reply as whomever it was to
set include                          # include message in replies

# Try and prevent imap timeouts
set imap_keepalive = 300

# Use gmail IMAP IDLE support.
set imap_idle
set imap_check_subscribed
unset imap_passive
unset imap_peek

# Sidebar mappings
set sidebar_visible = yes
set sidebar_width = 20
set sidebar_short_path = yes
set sidebar_next_new_wrap = yes
set mail_check_stats
set sidebar_format = '%B%?F? [%F]?%* %?N?%N/? %?S?%S?'
bind index o sidebar-open
bind index \Cp sidebar-prev
bind index \Cn sidebar-next
bind index,pager B sidebar-toggle-visible

macro index g1 '<sync-mailbox><enter-command>source ~/.mutt/profile_main<enter><change-folder>!<enter>'
macro index g2 '<sync-mailbox><enter-command>source ~/.mutt/profile_onef<enter><change-folder>!<enter>'
macro index g3 '<sync-mailbox><enter-command>source ~/.mutt/profile_mf<enter><change-folder>!<enter>'

# View and reply with different formats
reply-hook . '`touch /tmp/reply_flag`'
message-hook . 'set mailcap_path = ~/.mutt/mailcap`if [ -e /tmp/reply_flag ];then echo "_reply";rm -f /tmp/reply_flag;fi`'

source ~/.mutt/profile_main
