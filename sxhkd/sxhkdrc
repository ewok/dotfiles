# bspwm hotkeys
#
# Window manipulation
# ______________

# Close window
alt + shift + q
	bspc  node -c

# Kill window
alt + ctrl + shift + q
	bspc  node -k

alt + shift + space
	{bspc node -t floating && window-placer $(bspc query -T -d | grep -o '"state":"floating"' | wc -l),bspc node -t tiled}

# Toggle fullscreen
super + f
	bspc node -t {fullscreen,tiled}

# Make window sticky
alt + p
	bspc node -g sticky ; \
	notify-send -t 1000 "sticky"

# Lock a window from closing
alt + Escape
	bspc node -g locked ; \
	notify-send -t 1000 "lock/unlock"

### Map or unmap windows (functional equivalent of "minimize")
super + c
    whid dmenu

super + m
     whid hide

#
# Window moving and splitting
alt + super + {h,j,k,l}
	bspc node -p \~{west,south,north,east}

# Set splitting ratio of windows
alt + super + {1-9}
	bspc node -o 0.{1-9}

# Move current window to largest space or preselected area if there is one.
alt + super + Return
    windowpromoter

# Create a new "master area", splitting the whole desktop instead of just windows.
alt + shift + Return
	bspc node -n @/

# go (Shift=move) to desktop (and focus the monitor that the desktop is located on. Bspwm style)
alt + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} ^{1-9,10}

# Select previous / next desktop
alt + {n,m}
	bspc desktop -f {prev.occupied,next.occupied} 

alt +  {h,j,k,l}
    focusmover {west,south,north,east}

alt + shift + {h,j,k,l}
	windowgrabber {west,south,north,east}

alt + ctrl + {h,j,k,l}
	bspwm_resize.sh {west,south,north,east}

# Toggle monocle mode
alt + f
	bspc desktop -l next

# Balance tree
alt + b
	bspc node @/ -B ; \
	notify-send -t 1000 "Balancing the tree"

# Balance brother node. If you do this on biggest window of the desktop, it usually means balancing all windows with except the biggest.
super + alt + b
	bspc node @brother -B

# Undo balancing (equalize windows)
super + ctrl + b
	bspc node @/ -E

# Mirror and flip leaves of tree
alt + {comma,period}
	bspc node @/ -F {horizontal,vertical}

# Rotate leaves of tree
alt + shift + {comma,period}
	bspc node @/ -R {90,270}

# Change window gap

super + button{4,5}
	bspc config -d focused window_gap $((`bspc config -d focused window_gap` {+,-} 2 ))
#
# mouse bindings
~button1
	DidIClickDesktop.sh && gapgrab

~button2
	DidIClickDesktop.sh && BspwmDesktopMenu
#	DidIClickDesktop.sh && mygtkmenui -- .config/GTKmenu/BspwmDesktopMenui
#	DidIClickDesktop.sh && mygtkmenui -- .config/GTKmenu/BspwmWindowMenui

~button3
	DidIClickDesktop.sh && rofimenu -desktop
#DidIClickDesktop.sh && mygtkmenui -- .config/GTKmenu/LaunchMenu

# Spawn window manipulation menu
# Mod1 is alt
mod4 + @button2
    mygtkmenu -- .config/GTKmenu/BspwmMenu
	# BspwmWindowMenu

### Three finger swipe (left or right) to change desktop
@button{10,11}
    bspc desktop -f {prev,next}

### Three finger swipe (up) to launch dswitcher
@button8
    dswitcher & xdotool mousemove 640 400

#
# Touchpad "gestures" (depend on your touchpad driver, very likely to be unavailable)
#_____________________
# spawn programs
#

# run applications
alt + space
	dmenu_recent -fn 'xos4 Terminus:size=15' -i -l 14 -w 600 -y $PANEL_HEIGHT

alt + d
	albert show || albert ; \
	sleep 0.1; xdotool search --onlyvisible --pid $(pidof albert) --name "albert" windowactivate

alt + Return
	open-terminal-here

super + e
	default-terminal vifm

super + o ; {z,l,v,p,t,s,m, b}
	{zeal,ldoce5viewer,VirtualBox,pavucontrol,telegram-desktop;bspc desktop -f ,slack,gpmdp,$BROWSER}

shift + space
    szAnswer=$(zenity --entry --text "Todoist: Add Task" --entry-text "#proj @lab today"); td $szAnswer && dunstify "Task added" || dunstify -u critical "Error"

# Print Screen
Print
    flameshot full -p ~/Pictures/Screenshots/

super + Print
    flameshot gui -p ~/Pictures/Screenshots/

#
# Media keys
XF86AudioRaiseVolume
	changeVolumePulse '+5%'

	# changeVolume 2dB+ unmute

XF86AudioLowerVolume
    changeVolumePulse '-5%'

	# changeVolume 2dB- unmute

XF86AudioMute
	changeVolumePulse toggle

	# changeVolume 0dB mute

XF86MonBrightnessDown
 light -U 5

XF86MonBrightnessUp
 light -A 5

XF86Sleep
	systemctl suspend


# Lock
super + l
    lock

# make sxhkd reload its configuration files:
super + shift + Escape
	pkill -USR1 -x sxhkd ; \
	notify-send "sxhkd reloaded"

# In case bspwmrc fails to execute/you wish have plugged in a new monitor
super + shift + r
	bspwmrc

# Remove receptacles
super + BackSpace
  for i in $(bspc query -N -n .leaf.!window.local); do bspc node $i -k; done
