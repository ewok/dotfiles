command! gitk open -a SourceTree --args "%d"
" command! gitk open -a SmartGit --args "%d"
command! idea open -a "IntelliJ IDEA CE" .

command! hugo hugo "%a"
command! hugonew hugo new "%a" && vim "content/%a"
