{
  "python.linting.enabled": true,
  "python.jediEnabled": false,
  "python.venvFolders": ["~/share/venv",".venv"],
  "python.envFile": "${workspaceFolder}/.env",
  "python.autoComplete.showAdvancedMembers": true,
  "python.linting.pylintEnabled": true,
  "python.linting.flake8Enabled": true,
  "python.linting.banditEnabled": true,
  "python.linting.mypyEnabled": true,
  "python.linting.pydocstyleEnabled": true,
  "coc.source.emoji.filetypes": [
      "markdown",
      "vimwiki"
  ],
  "yaml.hover": true,
  "yaml.validate": true,
  "yaml.completion":true,
  "yaml.schemas": {
    "http://json.schemastore.org/ansible-stable-2.5": "/(playbooks|roles|tasks|handlers|defaults|vars)/*.(yml|yaml)",
    "kubernetes": "/!(playbooks|roles|tasks|handlers|defaults|vars)/*.(yml|yaml)"
  },
  "yaml.format.enable": true
}
