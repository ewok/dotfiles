set folder           = ~/mail               # mailbox location
set header_cache     = ~/tmp/mutt/work/cache/headers # where to store headers
set message_cachedir = ~/tmp/mutt/work/cache/bodies  # where to store bodies
set certificate_file = ~/tmp/mutt/work/cache/certificates  # where to store certs
# Account Settings ----------------------------------
set mbox_type    = Maildir
set spoolfile    = "+work/Inbox" #Default inbox.
set mbox         = "+work/Archive"
set postponed    = "+work/Drafts"
set trash        = "+work/Trash"

mailboxes +work/Inbox \
          +work/Archive \
          +work/Important \
          +work/Sent \
          +work/Junk \
          +work/Drafts \
          +work/DevOps \
          +work/NN \
          +work/LowPriority \
          +work/Trash

set from        ="`cat ~/.mutt_work`"
my_hdr Bcc: `cat ~/.mutt_work`
set realname        ="Artur Taranchiev"
set use_from        ="yes"
set envelope_from   ="yes"
set sendmail        ="msmtp_work -a work"

# ignore *                                # ignore all headers
# unignore from: to: cc: date: subject:   # show only these
# unhdr_order *                           # some distros order things by default
# hdr_order from: to: cc: date: subject:  # and in this order

macro index F "<shell-escape>mbsync_work work<enter>" "run mbsync to sync all mail"
macro index,pager A "<save-message>=work/Archive<enter><enter><sync-mailbox>y" "Archive"
macro index,pager D "<save-message>=work/Trash<enter><enter><sync-mailbox>y" "Trash"
macro index gi "<change-folder>=work/Inbox<enter>" "Go to inbox"
macro index gI "<change-folder>=work/Important<enter>" "Go to inbox"
macro index gd "<change-folder>=work/Drafts<enter>" "Go to drafts"

# Address book
set query_command="lbdbq '%s'"
bind editor <Tab> complete-query

set delete=ask-yes

set signature=~/.signature_work_plain
macro index,pager,attach rm "<enter-command>set signature=~/.signature_work_md<enter><reply>"
macro index,pager,attach rp "<enter-command>set signature=~/.signature_work_plain<enter><reply>"
macro index,pager,attach RM "<enter-command>set signature=~/.signature_work_md<enter><group-reply>"
macro index,pager,attach RP "<enter-command>set signature=~/.signature_work_plain<enter><group-reply>"
macro index,pager,attach LM "<enter-command>set signature=~/.signature_work_md<enter><list-reply>"
macro index,pager,attach LP "<enter-command>set signature=~/.signature_work_plain<enter><list-reply>"
