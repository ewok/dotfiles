[
  { "keys": [":"], "type": "function", "command": "enter_command_line_mode" },
  { "keys": ["TAB", "CTRL_Wl", "l"], "type": "function", "command": "focus_next" },
  { "keys": ["SHIFT_TAB", "CTRL_Wh", "h"], "type": "function", "command": "focus_previous" },
  { "keys": ["k", "UP"], "type": "function", "command": "move_up" },
  { "keys": ["j", "DOWN"], "type": "function", "command": "move_down" },
  { "keys": ["CTRL_U", "CTRL_B", "PAGE_UP"], "type": "function", "command": "page_up" },
  { "keys": ["CTRL_D", "CTRL_F", "PAGE_DOWN"], "type": "function", "command": "page_down" },
  { "keys": ["i", "ENTER"], "type": "function", "command": "activate" },
  { "keys": ["D", "DELETE", "BACKSPACE"], "type": "function", "command": "delete" },
  { "keys": [" "], "command": "todo toggle $n" },
  { "keys": ["tt", "tc"], "type": "function", "command": "toggle_console" },
  { "keys": ["tm"], "type": "function", "command": "toggle_metadata" },
  { "keys": ["/"], "type": "prompt", "command": "search \"\"", "cursorPosition": -2 },
  { "keys": ["nn"], "type": "prompt", "command": "mknote \"\"", "cursorPosition": -2 },
  { "keys": ["nt"], "type": "prompt", "command": "mktodo \"\"", "cursorPosition": -2 },
  { "keys": ["ni"], "type": "prompt", "command": "mknote \"`date`\"", "cursorPosition": -2 },
  { "keys": ["nb"], "type": "prompt", "command": "mkbook \"\"", "cursorPosition": -2 },
  { "keys": ["yy", "yn"], "type": "prompt", "command": "cp $n \"\"", "cursorPosition": -2 },
  { "keys": ["mm"], "type": "prompt", "command": "mv $n \"\"", "cursorPosition": -2 },
  { "keys": ["mk"], "type": "exec", "command": "mv $n kb"},
  { "keys": ["md"], "type": "exec", "command": "mv $n drafts"},
  { "keys": ["R"], "type": "prompt", "command": "ren $n \"\"", "cursorPosition": -2 },
  { "keys": ["qt", "gt"], "type": "prompt", "command": "tag add \"\" $n", "cursorPosition": 9 },
  { "keys": ["gs"], "type": "prompt", "command": "config notes.sortOrder.field"},
  { "keys": ["q"], "type": "exec", "command": "exit"},
  { "keys": ["s"], "type": "exec", "command": "sync"}
]
