#!/bin/bash

LC_ALL=en_US.UTF-8
COMMAND='gcalcli'
DEFAULT_CALENDAR=ewok@ewok.ru

if [[ $1 == "a" ]]; then
    $COMMAND --calendar=$DEFAULT_CALENDAR add ${@:2}
elif [[ $1 == "add" ]]; then
    $COMMAND --calendar=$DEFAULT_CALENDAR $@
elif [[ $1 == "q" ]]; then
    $COMMAND --calendar=$DEFAULT_CALENDAR quick "${*:2}"
elif [[ $1 == "ag" ]]; then
    $COMMAND agenda ${@:2}
elif [[ $1 == "m" ]]; then
    $COMMAND calm --monday ${@:2}
elif [[ $1 == "w" ]]; then
    $COMMAND calw --monday ${@:2}
else
    $COMMAND $@
fi
