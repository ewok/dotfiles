#!/bin/env bash

set -e

if ! pgrep -f davmail
then
    davmail >/dev/null 2>&1 || echo "Error running DAVmail" &
    # Give a time to DAVmail
    sleep 2
fi

ping -q -w1 -c1 google.com &>/dev/null || exit 1

if ! pgrep mbsync
then
    USERNAME=$(cat ~/.mutt_work)
    sed -e "s/%USERNAME%/$USERNAME/" ~/.mbsyncrc > /tmp/.mbsyncrc
    mbsync -c /tmp/.mbsyncrc "$@"
    rm -f /tmp/.mbsyncrc

    notmuch new
else
    exit 2
fi
